//#include <stdio.h>
#include <stdlib.h>

int main(){
	int n;
	int i;
	int * score;
	printf("๏ฟฝะป๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝิท๏ฟฝ : ");
	scanf("%d",&n);
	
	score = (int *)malloc(n*sizeof(int));//->(int *) ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝศฏ 
	
	printf("๏ฟฝะป๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ %d ๏ฟฝ๏ฟฝ๏ฟฝิดฯด๏ฟฝ\n",n);
	
	for(i=0;i<n;i++){
		
		score[i]=i;
		printf("%d\n",score[i]);
	}
	
	free(score); 
	
	return 0;
}
